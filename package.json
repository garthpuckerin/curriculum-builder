{
  "name": "curriculum-builder",
  "version": "1.1.0",
  "private": true,
  "description": "AI-Assisted Instructional Design — Generate structured training curricula for Docebo, Workday Learning, SuccessFactors",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "commit": "cz",
    "docs": "typedoc",
    "docs:serve": "typedoc && npx serve docs",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "validate:ci": "npm run typecheck && npm run lint && npm run test:coverage"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "next": "^15.5.12",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "swagger-ui-react": "^5.11.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/cz-commitlint": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "lodash": ">=4.17.22",
    "tmp": ">=0.2.4"
  }
}
